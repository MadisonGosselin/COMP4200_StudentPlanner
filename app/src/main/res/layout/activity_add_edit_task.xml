<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/homepage_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="18dp"
            android:src="@drawable/team_logo_dark"
            android:scaleType="fitCenter"
            android:contentDescription="Team Logo" />

        <TextView
            android:id="@+id/addEditTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add / Edit Task"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="22dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task Title"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/taskTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter task title"
            android:background="@drawable/input_box"
            android:textColor="#000000"
            android:textColorHint="#80000000"
            android:padding="14dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Course / Subject"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/subjectInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter course or subject"
            android:background="@drawable/input_box"
            android:textColor="#000000"
            android:textColorHint="#80000000"
            android:padding="14dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due Date"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/dueDateInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter due date"
            android:background="@drawable/input_box"
            android:textColor="#000000"
            android:textColorHint="#80000000"
            android:padding="14dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priority"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/priorityGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_box"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/priorityLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low"
                android:textColor="#2E7D32"
                android:layout_marginEnd="20dp" />

            <RadioButton
                android:id="@+id/priorityMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:textColor="#F9A825"
                android:checked="true"
                android:layout_marginEnd="20dp" />

            <RadioButton
                android:id="@+id/priorityHigh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textColor="#C62828" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notes"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/notesInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:hint="Enter notes"
            android:background="@drawable/input_box"
            android:textColor="#000000"
            android:textColorHint="#80000000"
            android:padding="14dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/saveTaskButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Task"
            android:textColor="#FFFFFF"
            android:background="@drawable/action_button"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/cancelTaskButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:backgroundTint="#616161"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>