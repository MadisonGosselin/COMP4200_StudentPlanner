<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/homepage_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/homeLogo"
            android:layout_width="180dp"
            android:layout_height="90dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/team_logo_dark"
            android:scaleType="fitCenter"
            android:contentDescription="Team Logo" />

        <TextView
            android:id="@+id/welcomeMainText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/subtitleMainText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Here is your study planner overview"
            android:textColor="#D9D9D9"
            android:textSize="14sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/card_box">

                <TextView
                    android:id="@+id/totalTasksText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="#1E88E5"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/card_box">

                <TextView
                    android:id="@+id/completedTasksText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textColor="#2E7D32"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_box">

                <TextView
                    android:id="@+id/overdueTasksText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#C62828"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overdue"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/addTaskButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Task"
            android:textColor="#FFFFFF"
            android:background="@drawable/action_button"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tasksSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upcoming Tasks"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/taskCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_box"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/task1Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="COMP 4200 Assignment"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/task1Priority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textColor="#C62828"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/task1DueDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Due: March 30"
                android:textColor="#444444"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/task1Status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Pending"
                android:textColor="#F9A825"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/taskCard2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_box"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/task2Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Database Quiz Review"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/task2Priority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium"
                    android:textColor="#F9A825"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/task2DueDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Due: April 2"
                android:textColor="#444444"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/task2Status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Completed"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/emptyTasksText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No more tasks to display."
            android:textColor="#D9D9D9"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>